    // ============================================================
    // ROLE SELECTION
    // ============================================================
    window.selectRole = function(role) {
      selectedRole = role;
      document.querySelectorAll('.role-option').forEach(el => {
        el.classList.toggle('active', el.dataset.role === role);
      });
      
      const studentFields = document.getElementById('studentFields');
      const lecturerFields = document.getElementById('lecturerFields');
      const adminFields = document.getElementById('adminFields');
      const btnText = document.getElementById('registerBtnText');
      
      studentFields.classList.add('hidden');
      lecturerFields.classList.add('hidden');
      adminFields.classList.add('hidden');
      
      if (role === 'student') {
        studentFields.classList.remove('hidden');
        btnText.textContent = 'Register as Student';
        document.getElementById('regRole').value = 'student';
        document.querySelectorAll('#studentFields input, #studentFields select').forEach(el => {
          if (el.id !== 'regStudentId') el.required = true;
        });
      } else if (role === 'lecturer') {
        lecturerFields.classList.remove('hidden');
        btnText.textContent = 'Register as Lecturer';
        document.getElementById('regRole').value = 'lecturer';
        document.querySelectorAll('#lecturerFields input, #lecturerFields textarea').forEach(el => {
          if (el.id !== 'lecturerDept' && el.id !== 'lecturerQualifications') el.required = true;
        });
      } else {
        adminFields.classList.remove('hidden');
        btnText.textContent = 'Register as Administrator';
        document.getElementById('regRole').value = 'admin';
        document.querySelectorAll('#adminFields input, #adminFields select, #adminFields textarea').forEach(el => {
          if (el.id !== 'adminStaffId' && el.id !== 'adminAuthLetter') el.required = true;
        });
      }
    };

    // ============================================================
    // UNIVERSITY MANAGEMENT FOR LECTURERS
    // ============================================================
    window.addUniversity = function() {
      const input = document.getElementById('lecturerUniversityInput');
      const uni = input.value.trim();
      if (!uni) {
        showToast('⚠️ Please enter a university name.', 'error');
        return;
      }
      if (lecturerUniversities.includes(uni)) {
        showToast('⚠️ University already added.', 'warning');
        return;
      }
      lecturerUniversities.push(uni);
      updateUniversityList();
      input.value = '';
      input.focus();
    };

    function updateUniversityList() {
      const container = document.getElementById('universityList');
      if (lecturerUniversities.length === 0) {
        container.innerHTML = '<span style="color:#64748b; font-size:12px;">No universities added yet</span>';
        return;
      }
      container.innerHTML = lecturerUniversities.map(uni => `
        <span class="multi-select-item">
          ${uni}
          <span class="remove" onclick="removeUniversity('${uni}')">&times;</span>
        </span>
      `).join('');
      document.getElementById('lecturerUniversities').value = JSON.stringify(lecturerUniversities);
    }

    window.removeUniversity = function(uni) {
      lecturerUniversities = lecturerUniversities.filter(u => u !== uni);
      updateUniversityList();
    };

    // ============================================================
    // GENERATE SESSION CODE
    // ============================================================
    function generateSessionCode() {
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
      let code = '';
      for (let i = 0; i < 6; i++) {
        code += chars.charAt(Math.floor(Math.random() * chars.length));
      }
      return code;
    }

    // ============================================================
    // EMAIL VALIDATION
    // ============================================================
    function isValidSchoolEmail(email) {
      const patterns = [
        /\.ac\.ke$/i,
        /@uonbi\.ac\.ke$/i,
        /@ku\.ac\.ke$/i,
        /@mu\.ac\.ke$/i,
        /@jkuat\.ac\.ke$/i,
        /@egerton\.ac\.ke$/i,
        /@maseno\.ac\.ke$/i,
        /@tukenya\.ac\.ke$/i,
        /@strathmore\.edu$/i,
        /@usiu\.ac\.ke$/i,
        /@uoeld\.ac\.ke$/i,
        /@kisiiuniversity\.ac\.ke$/i,
        /@mut\.ac\.ke$/i,
        /@must\.ac\.ke$/i,
        /@mkuniversity\.ac\.ke$/i,
        /@kcauniversity\.ac\.ke$/i,
        /@anu\.ac\.ke$/i,
        /@daystar\.ac\.ke$/i,
        /@cuea\.edu$/i,
        /@student\./i
      ];
      return patterns.some(p => p.test(email));
    }

    // ============================================================
    // GENERATE VERIFICATION TOKEN
    // ============================================================
    function generateVerificationToken() {
      return Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
    }

    // ============================================================
    // SEND VERIFICATION EMAIL
    // ============================================================
    async function sendVerificationEmail(email, name, token, role) {
      try {
        const verificationLink = window.location.origin + window.location.pathname + '?verify=' + token + '&email=' + encodeURIComponent(email);
        
        const templateParams = {
          to_email: email,
          to_name: name,
          verification_link: verificationLink,
          role: role.charAt(0).toUpperCase() + role.slice(1)
        };

        const response = await emailjs.send(
          'YOUR_SERVICE_ID',
          'YOUR_TEMPLATE_ID',
          templateParams
        );

        console.log('📧 Verification email sent successfully');
        return true;
      } catch (error) {
        console.error('❌ Failed to send verification email:', error);
        const link = window.location.origin + window.location.pathname + '?verify=' + token + '&email=' + encodeURIComponent(email);
        console.log('📧 VERIFICATION LINK:', link);
        return false;
      }
    }

    // ============================================================
    // AVATAR HANDLING
    // ============================================================
    function handleAvatarUpload(event) {
      const file = event.target.files[0];
      if (!file) return;
      
      const reader = new FileReader();
      reader.onload = function(e) {
        const imageData = e.target.result;
        if (currentUser) {
          currentUser.avatar = imageData;
          const users = getUsers();
          const userIndex = users.findIndex(u => u.id === currentUser.id);
          if (userIndex !== -1) {
            users[userIndex].avatar = imageData;
            saveUsers(users);
            saveCurrentUser(currentUser);
            updateUserInfo();
            showToast('✅ Profile photo updated!', 'success');
          }
        }
      };
      reader.readAsDataURL(file);
    }

    // ============================================================
    // UNIVERSITY DATA POPULATION
    // ============================================================
    function populateUniversities() {
      const selects = ['regUniversity', 'adminUniversity'];
      selects.forEach(id => {
        const select = document.getElementById(id);
        if (!select) return;
        
        select.innerHTML = '<option value="">Select University</option>';
        const universities = Object.keys(KENYAN_UNIVERSITIES).sort();
        universities.forEach(university => {
          const option = document.createElement('option');
          option.value = university;
          option.textContent = university;
          select.appendChild(option);
        });
      });
    }

    function updateCourses() {
      const university = document.getElementById('regUniversity').value;
      const schoolSelect = document.getElementById('regSchool');
      const deptSelect = document.getElementById('regDepartment');
      const courseSelect = document.getElementById('regCourse');
      
      schoolSelect.innerHTML = '<option value="">Select School</option>';
      deptSelect.innerHTML = '<option value="">Select Department</option>';
      courseSelect.innerHTML = '<option value="">Select Course</option>';
      
      if (!university || !KENYAN_UNIVERSITIES[university]) return;
      
      const uniData = KENYAN_UNIVERSITIES[university];
      const schools = Object.keys(uniData.schools).sort();
      
      schools.forEach(school => {
        const option = document.createElement('option');
        option.value = school;
        option.textContent = school;
        schoolSelect.appendChild(option);
      });
    }

    function updateDepartments() {
      const university = document.getElementById('regUniversity').value;
      const school = document.getElementById('regSchool').value;
      const deptSelect = document.getElementById('regDepartment');
      const courseSelect = document.getElementById('regCourse');
      
      deptSelect.innerHTML = '<option value="">Select Department</option>';
      courseSelect.innerHTML = '<option value="">Select Course</option>';
      
      if (!university || !school || !KENYAN_UNIVERSITIES[university]) return;
      
      const uniData = KENYAN_UNIVERSITIES[university];
      if (!uniData.schools[school]) return;
      
      const departments = uniData.schools[school].departments || [];
      departments.sort().forEach(dept => {
        const option = document.createElement('option');
        option.value = dept;
        option.textContent = dept;
        deptSelect.appendChild(option);
      });
    }

    function updateCoursesByDept() {
      const university = document.getElementById('regUniversity').value;
      const school = document.getElementById('regSchool').value;
      const department = document.getElementById('regDepartment').value;
      const courseSelect = document.getElementById('regCourse');
      
      courseSelect.innerHTML = '<option value="">Select Course</option>';
      
      if (!university || !school || !department || !KENYAN_UNIVERSITIES[university]) return;
      
      const uniData = KENYAN_UNIVERSITIES[university];
      if (!uniData.schools[school] || !uniData.schools[school].courses) return;
      
      const courses = uniData.schools[school].courses[department] || [];
      courses.sort().forEach(course => {
        const option = document.createElement('option');
        option.value = course;
        option.textContent = course;
        courseSelect.appendChild(option);
      });
    }

    // ============================================================
    // ADMIN REGISTRATION CODE VALIDATION
    // ============================================================
    function validateAdminCode(code) {
      const ADMIN_CODES = ['ADMIN2024', 'UNIADMIN2024', 'KENYAADMIN2024', 'ADMIN-DEMO-2024'];
      return ADMIN_CODES.includes(code);
    }

    // ============================================================
    // AUTH: REGISTER
    // ============================================================
    window.handleRegister = async function(e) {
      e.preventDefault();

      const role = document.getElementById('regRole').value;
      const password = document.getElementById('regPassword').value;
      const confirmPassword = document.getElementById('regConfirmPassword').value;

      if (password.length < 6) {
        showToast('⚠️ Password must be at least 6 characters.', 'error');
        return;
      }

      if (password !== confirmPassword) {
        showToast('⚠️ Passwords do not match.', 'error');
        return;
      }

      let userData = {};

      if (role === 'student') {
        const name = document.getElementById('regName').value.trim();
        const email = document.getElementById('regEmail').value.trim();
        const university = document.getElementById('regUniversity').value;
        const school = document.getElementById('regSchool').value;
        const department = document.getElementById('regDepartment').value;
        const year = document.getElementById('regYear').value;
        const course = document.getElementById('regCourse').value;
        const studentId = document.getElementById('regStudentId').value.trim();
        const admissionNo = document.getElementById('regAdmissionNo').value.trim();

        if (!name || !email || !university || !school || !department || !year || !course || !admissionNo) {
          showToast('⚠️ Please fill in all required fields.', 'error');
          return;
        }

        if (!isValidSchoolEmail(email)) {
          showToast('⚠️ Please use a valid Kenyan university email (.ac.ke)', 'error');
          return;
        }

        const users = getUsers();
        if (users.find(u => u.email === email)) {
          showToast('⚠️ An account with this email already exists.', 'error');
          return;
        }

        userData = {
          name,
          email,
          university,
          school,
          department,
          yearOfStudy: year,
          course,
          studentId: studentId || '',
          admissionNo,
          role: 'student',
          verified: false,
          verificationToken: generateVerificationToken(),
          avatar: null,
          createdAt: new Date().toISOString()
        };
      } else if (role === 'lecturer') {
        const name = document.getElementById('lecturerName').value.trim();
        const email = document.getElementById('lecturerEmail').value.trim();
        const phone = document.getElementById('lecturerPhone').value.trim();
        const department = document.getElementById('lecturerDept').value.trim();
        const qualifications = document.getElementById('lecturerQualifications').value.trim();
        const universities = JSON.parse(document.getElementById('lecturerUniversities').value || '[]');

        if (!name || !email || !phone) {
          showToast('⚠️ Please fill in all required fields.', 'error');
          return;
        }

        if (universities.length === 0) {
          showToast('⚠️ Please add at least one university.', 'error');
          return;
        }

        const users = getUsers();
        if (users.find(u => u.email === email)) {
          showToast('⚠️ An account with this email already exists.', 'error');
          return;
        }

        const docInput = document.getElementById('lecturerDocuments');
        const documents = docInput.files ? Array.from(docInput.files).map(f => f.name) : [];

        userData = {
          name,
          email,
          phone,
          department: department || 'Not specified',
          universities: universities,
          qualifications: qualifications || '',
          documents: documents,
          role: 'lecturer',
          verified: false,
          verificationToken: generateVerificationToken(),
          avatar: null,
          createdAt: new Date().toISOString(),
          verificationStatus: 'pending'
        };
      } else {
        const regCode = document.getElementById('adminRegCode').value.trim();
        const name = document.getElementById('adminName').value.trim();
        const email = document.getElementById('adminEmail').value.trim();
        const phone = document.getElementById('adminPhone').value.trim();
        const department = document.getElementById('adminDept').value.trim();
        const university = document.getElementById('adminUniversity').value;
        const staffId = document.getElementById('adminStaffId').value.trim();
        const authLetter = document.getElementById('adminAuthLetter');

        if (!validateAdminCode(regCode)) {
          showToast('⚠️ Invalid admin registration code.', 'error');
          return;
        }

        if (!name || !email || !phone || !department || !university) {
          showToast('⚠️ Please fill in all required fields.', 'error');
          return;
        }

        const users = getUsers();
        if (users.find(u => u.email === email)) {
          showToast('⚠️ An account with this email already exists.', 'error');
          return;
        }

        const authLetterName = authLetter.files && authLetter.files[0] ? authLetter.files[0].name : '';

        userData = {
          name,
          email,
          phone,
          department,
          university,
          staffId: staffId || '',
          authLetter: authLetterName,
          role: 'admin',
          verified: false,
          verificationToken: generateVerificationToken(),
          avatar: null,
          createdAt: new Date().toISOString(),
          adminStatus: 'pending'
        };
      }

      const users = getUsers();
      const newUser = {
        id: Date.now().toString(),
        password,
        ...userData
      };

      users.push(newUser);
      saveUsers(users);

      showToast('📧 Sending verification email...', '');
      
      const emailSent = await sendVerificationEmail(
        newUser.email, 
        newUser.name, 
        newUser.verificationToken,
        newUser.role
      );
      
      if (emailSent) {
        showToast(`✅ Verification email sent to ${newUser.email}.`, 'success');
        showToast('📧 Click the "Verify Email" link in the email to activate your account.', 'success');
      } else {
        showToast('⚠️ Could not send email. Check console for verification link.', 'warning');
      }

      document.getElementById('regPassword').value = '';
      document.getElementById('regConfirmPassword').value = '';
      
      showToast('✅ Registration successful! Please check your email for verification.', 'success');
    };

    // ============================================================
    // AUTH: LOGIN
    // ============================================================
    window.handleLogin = function(e) {
      e.preventDefault();

      const email = document.getElementById('loginEmail').value.trim();
      const password = document.getElementById('loginPassword').value;

      if (!email || !password) {
        showToast('⚠️ Please enter email and password.', 'error');
        return;
      }

      const users = getUsers();
      const user = users.find(u => u.email === email && u.password === password);

      if (!user) {
        showToast('❌ Invalid email or password.', 'error');
        return;
      }

      if (!user.verified) {
        showToast('⚠️ Please verify your email before logging in.', 'error');
        return;
      }

      if (user.role === 'lecturer' && user.verificationStatus !== 'verified') {
        showToast('⚠️ Your lecturer account is pending verification.', 'warning');
        if (user.verificationStatus === 'pending') {
          showToast('📧 You will be notified once your account is verified.', 'warning');
        } else {
          showToast('❌ Your verification was rejected. Please contact the administrator.', 'error');
        }
      }

      currentUser = user;
      saveCurrentUser(user);
      showToast(`✅ Welcome back, ${user.name}!`, 'success');
      showDashboard();
    };

