<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Smart Campus Attendance System - Kenya</title>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <!-- EmailJS -->
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
  <style>
    /* ===== RESET & BASE ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      min-height: 100vh;
      padding: 16px;
      color: #e2e8f0;
      overflow-x: hidden;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    /* ===== WELCOME PAGE ===== */
    #welcomePage {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      z-index: 10000;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      padding: 20px;
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    #welcomePage.hidden {
      opacity: 0;
      transform: scale(1.1);
      pointer-events: none;
    }
    .welcome-content {
      max-width: 800px;
      width: 100%;
      text-align: center;
    }
    .welcome-logo {
      font-size: 80px;
      margin-bottom: 20px;
      animation: float 3s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }
    .welcome-title {
      font-size: 42px;
      font-weight: 800;
      background: linear-gradient(135deg, #667eea, #764ba2, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 10px;
    }
    .welcome-subtitle {
      font-size: 18px;
      color: #94a3b8;
      margin-bottom: 30px;
    }
    .welcome-features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin: 30px 0;
    }
    .welcome-feature {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 20px;
      text-align: center;
      animation: slideUp 0.6s ease forwards;
      opacity: 0;
      transform: translateY(30px);
    }
    .welcome-feature:nth-child(1) { animation-delay: 0.2s; }
    .welcome-feature:nth-child(2) { animation-delay: 0.4s; }
    .welcome-feature:nth-child(3) { animation-delay: 0.6s; }
    .welcome-feature:nth-child(4) { animation-delay: 0.8s; }
    
    @keyframes slideUp {
      to { opacity: 1; transform: translateY(0); }
    }
    .welcome-feature i {
      font-size: 32px;
      color: #a78bfa;
      margin-bottom: 10px;
      display: block;
    }
    .welcome-feature h4 {
      font-size: 14px;
      margin-bottom: 4px;
    }
    .welcome-feature p {
      font-size: 12px;
      color: #94a3b8;
    }
    .welcome-progress {
      width: 100%;
      max-width: 400px;
      height: 4px;
      background: rgba(255,255,255,0.1);
      border-radius: 4px;
      margin: 20px auto;
      overflow: hidden;
    }
    .welcome-progress-bar {
      height: 100%;
      background: linear-gradient(90deg, #667eea, #764ba2);
      border-radius: 4px;
      animation: progress 3s ease-in-out forwards;
      width: 0%;
    }
    @keyframes progress {
      0% { width: 0%; }
      100% { width: 100%; }
    }
    .welcome-btn {
      padding: 14px 40px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      border: none;
      border-radius: 50px;
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
      margin-top: 10px;
    }
    .welcome-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 30px rgba(102, 126, 234, 0.5);
    }
    .welcome-version {
      margin-top: 20px;
      font-size: 12px;
      color: #64748b;
    }
    
    /* ===== GLASS CARD ===== */
    .glass-card {
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      padding: 24px 20px;
      margin-bottom: 16px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }
    
    /* ===== HEADER ===== */
    .brand-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 14px;
    }
    .brand-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .brand-icon {
      background: linear-gradient(135deg, #667eea, #764ba2);
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      color: #fff;
      box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
    }
    .brand-header h1 {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.5px;
    }
    .brand-header h1 span { color: #a78bfa; }
    .brand-header .sub {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 2px;
    }
    .user-info {
      display: flex;
      align-items: center;
      gap: 12px;
      background: rgba(255,255,255,0.05);
      padding: 8px 16px;
      border-radius: 30px;
      font-size: 13px;
    }
    .user-info .avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea, #764ba2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 16px;
      overflow: hidden;
      cursor: pointer;
      position: relative;
    }
    .user-info .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .user-info .avatar .upload-hint {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(0,0,0,0.7);
      font-size: 8px;
      text-align: center;
      padding: 2px;
      opacity: 0;
      transition: 0.2s;
    }
    .user-info .avatar:hover .upload-hint {
      opacity: 1;
    }
    .logout-btn {
      background: rgba(239,68,68,0.2);
      border: 1px solid rgba(239,68,68,0.3);
      color: #fca5a5;
      padding: 4px 12px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 12px;
      transition: 0.2s;
    }
    .logout-btn:hover {
      background: rgba(239,68,68,0.3);
    }
    
    /* ===== STATUS BANNER ===== */
    .status-banner {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.15);
      border-radius: 12px;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: #6ee7b7;
      margin: 12px 0 16px;
    }
    .status-banner i { font-size: 16px; }
    .status-banner .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #34d399;
      display: inline-block;
      animation: pulse-dot 1.5s infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }
    
    /* ===== FORM ELEMENTS ===== */
    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #cbd5e1;
      margin-bottom: 4px;
    }
    .label-icon { color: #a78bfa; margin-right: 4px; }
    .input-group { margin-bottom: 14px; }
    .input-group-required label::after {
      content: ' *';
      color: #ef4444;
    }
    
    input, select, textarea {
      width: 100%;
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      color: #f1f5f9;
      font-size: 15px;
      transition: 0.2s;
      font-family: inherit;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: #a78bfa;
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.15);
    }
    input::placeholder, textarea::placeholder { color: #64748b; }
    select option { background: #1e293b; color: #f1f5f9; }
    textarea { resize: vertical; min-height: 60px; }
    
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .row-3 { grid-template-columns: 1fr 1fr 1fr; }
    
    /* ===== BUTTONS ===== */
    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 14px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      transition: 0.25s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: #fff;
      box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
    }
    .btn-primary:hover:not(:disabled) {
      transform: scale(1.02);
      box-shadow: 0 6px 28px rgba(102, 126, 234, 0.4);
    }
    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    .btn-success {
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff;
      box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
    }
    .btn-success:hover:not(:disabled) {
      transform: scale(1.02);
      box-shadow: 0 6px 28px rgba(16, 185, 129, 0.4);
    }
    .btn-danger {
      background: linear-gradient(135deg, #ef4444, #dc2626);
      color: #fff;
    }
    .btn-secondary {
      background: rgba(255, 255, 255, 0.06);
      color: #cbd5e1;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .btn-secondary:hover { background: rgba(255, 255, 255, 0.1); }
    .btn-warning {
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: #fff;
    }
    .btn-info {
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: #fff;
    }
    .btn-block { width: 100%; }
    .btn-sm { padding: 8px 16px; font-size: 13px; }
    
    /* ===== ROLE SELECTOR ===== */
    .role-selector {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
      margin-bottom: 20px;
    }
    .role-option {
      padding: 16px;
      border: 2px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      text-align: center;
      cursor: pointer;
      transition: 0.3s;
      background: rgba(255,255,255,0.02);
    }
    .role-option:hover {
      border-color: rgba(167,139,250,0.3);
      background: rgba(167,139,250,0.05);
    }
    .role-option.active {
      border-color: #a78bfa;
      background: rgba(167,139,250,0.1);
    }
    .role-option i {
      font-size: 32px;
      display: block;
      margin-bottom: 8px;
    }
    .role-option .title {
      font-weight: 600;
      font-size: 14px;
    }
    .role-option .desc {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 4px;
    }
    
    /* ===== VERIFICATION STATUS ===== */
    .verification-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
    }
    .verification-badge.verified {
      background: rgba(16,185,129,0.15);
      color: #6ee7b7;
    }
    .verification-badge.pending {
      background: rgba(245,158,11,0.15);
      color: #fbbf24;
    }
    .verification-badge.unverified {
      background: rgba(239,68,68,0.15);
      color: #fca5a5;
    }
    
    /* ===== CODE DISPLAY ===== */
    .code-display {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 12px;
      padding: 16px;
      text-align: center;
      margin: 12px 0;
      border: 2px dashed rgba(167, 139, 250, 0.3);
    }
    .code-display .code {
      font-size: 32px;
      font-weight: 800;
      letter-spacing: 6px;
      color: #a78bfa;
      font-family: 'Courier New', monospace;
    }
    .code-display .label { font-size: 11px; color: #94a3b8; margin-bottom: 4px; }
    
    /* ===== ATTENDANCE LIST ===== */
    .attendance-list {
      max-height: 400px;
      overflow-y: auto;
      margin-top: 10px;
    }
    .attendance-list::-webkit-scrollbar { width: 4px; }
    .attendance-list::-webkit-scrollbar-thumb { background: #4a4a6a; border-radius: 10px; }
    
    .attendee-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 8px;
      margin-bottom: 4px;
      font-size: 13px;
      border-left: 3px solid #10b981;
    }
    .attendee-item .name { font-weight: 600; color: #e2e8f0; }
    .attendee-item .details { color: #94a3b8; font-size: 12px; }
    .attendee-item .time { color: #6ee7b7; font-size: 12px; }
    .attendee-item .badge {
      background: rgba(16, 185, 129, 0.15);
      color: #6ee7b7;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 600;
    }
    
    /* ===== STUDENT RECORDS ===== */
    .student-record-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 12px;
      transition: 0.3s;
    }
    .student-record-card:hover {
      background: rgba(255,255,255,0.06);
    }
    .student-record-card .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 8px;
    }
    .student-record-card .name {
      font-size: 16px;
      font-weight: 600;
      color: #e2e8f0;
    }
    .student-record-card .admission {
      font-size: 12px;
      color: #94a3b8;
    }
    .student-record-card .stats {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-size: 13px;
      color: #94a3b8;
      margin-top: 4px;
    }
    .student-record-card .stats span {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .student-record-card .stats .present { color: #6ee7b7; }
    .student-record-card .stats .absent { color: #fca5a5; }
    .student-record-card .courses {
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .student-record-card .course-item {
      display: flex;
      justify-content: space-between;
      padding: 4px 0;
      font-size: 13px;
      color: #cbd5e1;
    }
    .student-record-card .course-item .course-name {
      color: #94a3b8;
    }
    .student-record-card .course-item .attendance-count {
      font-weight: 600;
    }
    .attendance-progress {
      width: 100%;
      height: 6px;
      background: rgba(255,255,255,0.05);
      border-radius: 4px;
      margin-top: 4px;
      overflow: hidden;
    }
    .attendance-progress .bar {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s;
    }
    .attendance-progress .bar.high { background: #10b981; }
    .attendance-progress .bar.medium { background: #f59e0b; }
    .attendance-progress .bar.low { background: #ef4444; }
    
    /* ===== SEARCH AND FILTER ===== */
    .search-container {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .search-container input,
    .search-container select {
      flex: 1;
      min-width: 150px;
      padding: 10px 14px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      color: #f1f5f9;
      font-size: 14px;
    }
    .search-container input:focus,
    .search-container select:focus {
      outline: none;
      border-color: #a78bfa;
    }
    
    /* ===== AUTH PANELS ===== */
    .auth-container {
      max-width: 550px;
      margin: 0 auto;
    }
    .auth-tabs {
      display: flex;
      gap: 4px;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 14px;
      padding: 4px;
      margin-bottom: 20px;
    }
    .auth-tab {
      flex: 1;
      padding: 10px;
      text-align: center;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
      transition: 0.2s;
      background: transparent;
      color: #94a3b8;
    }
    .auth-tab.active {
      background: rgba(167, 139, 250, 0.15);
      color: #a78bfa;
    }
    .auth-tab:hover:not(.active) { color: #e2e8f0; }
    
    .auth-panel { display: none; }
    .auth-panel.active { display: block; }
    
    /* ===== DASHBOARD ===== */
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin: 16px 0;
    }
    .stat-card {
      background: rgba(255,255,255,0.04);
      border-radius: 16px;
      padding: 16px;
      text-align: center;
      border: 1px solid rgba(255,255,255,0.06);
      cursor: pointer;
      transition: 0.3s;
    }
    .stat-card:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-2px);
    }
    .stat-card .number {
      font-size: 28px;
      font-weight: 800;
      color: #a78bfa;
    }
    .stat-card .label {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 4px;
    }
    
    .session-history {
      margin-top: 16px;
    }
    .history-item {
      background: rgba(255,255,255,0.03);
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 8px;
      border-left: 3px solid #667eea;
    }
    .history-item .header {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .history-item .course { font-weight: 600; }
    .history-item .meta { font-size: 12px; color: #94a3b8; }
    .history-item .count { color: #6ee7b7; font-size: 13px; }
    
    /* ===== ADMIN VERIFICATION LIST ===== */
    .verification-list {
      max-height: 400px;
      overflow-y: auto;
    }
    .verification-item {
      background: rgba(255,255,255,0.03);
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 10px;
      border: 1px solid rgba(255,255,255,0.06);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .verification-item .info {
      flex: 1;
    }
    .verification-item .info .name {
      font-weight: 600;
      font-size: 15px;
    }
    .verification-item .info .details {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 2px;
    }
    .verification-item .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .verification-item .actions .btn {
      padding: 6px 14px;
      font-size: 12px;
    }
    
    /* ===== TOAST ===== */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(120px);
      background: #1e293b;
      color: #f1f5f9;
      padding: 14px 24px;
      border-radius: 16px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.5);
      z-index: 999;
      font-size: 14px;
      transition: 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      max-width: 90%;
      text-align: center;
      border-left: 4px solid #a78bfa;
    }
    .toast.show { transform: translateX(-50%) translateY(0); }
    .toast.success { border-left-color: #34d399; }
    .toast.error { border-left-color: #ef4444; }
    .toast.warning { border-left-color: #f59e0b; }
    
    .spinner {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 3px solid rgba(255,255,255,0.15);
      border-radius: 50%;
      border-top-color: #fff;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    
    .text-muted { color: #64748b; font-size: 12px; text-align: center; margin-top: 12px; }
    .mt-1 { margin-top: 6px; }
    .mt-2 { margin-top: 12px; }
    .mt-3 { margin-top: 20px; }
    .hidden { display: none !important; }
    .text-center { text-align: center; }
    .text-success { color: #6ee7b7; }
    .text-danger { color: #fca5a5; }
    .text-warning { color: #fbbf24; }
    .text-muted-small { color: #64748b; font-size: 12px; }
    
