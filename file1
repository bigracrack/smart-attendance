    // ============================================================
    function renderStudentsPanel() {
      const container = document.getElementById('studentsContent');
      const users = getUsers();
      const records = getAttendanceRecords();
      const sessions = getSessions();

      let html = `
        <div style="margin-bottom:16px;">
          <h3 style="font-size:16px; color:#e2e8f0;">
            <i class="fas fa-users" style="color:#a78bfa;"></i> 
            ${currentUser.role === 'admin' ? 'All Students - ' : ''}Attendance Records
          </h3>
          <p style="font-size:13px; color:#94a3b8; margin-top:4px;">
            Complete attendance history for each student with course breakdown
          </p>
        </div>
        
        <div class="search-container">
          <input type="text" id="studentSearch" placeholder="🔍 Search by name, admission number, or course..." oninput="filterStudents()" />
          <select id="courseFilter" onchange="filterStudents()">
            <option value="">All Courses</option>
          </select>
          <select id="universityFilter" onchange="filterStudents()">
            <option value="">All Universities</option>
          </select>
        </div>
      `;

      // Get all students
      let students = [];
      if (currentUser.role === 'admin') {
        students = users.filter(u => u.role === 'student');
      } else if (currentUser.role === 'lecturer') {
        // Lecturer sees students who have attended their sessions
        const studentIds = new Set(records.filter(r => r.hostId === currentUser.id).map(r => r.studentId));
        students = users.filter(u => u.role === 'student' && studentIds.has(u.id));
      } else {
        // Student sees their own records
        students = users.filter(u => u.id === currentUser.id);
      }

      // Populate filters
      const courses = [...new Set(records.map(r => r.course))].filter(Boolean);
      const universities = [...new Set(users.filter(u => u.role === 'student').map(u => u.university))].filter(Boolean);
      
      const courseFilter = document.getElementById('courseFilter');
      const uniFilter = document.getElementById('universityFilter');
      
      courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c;
        courseFilter.appendChild(opt);
      });
      
      universities.forEach(u => {
        const opt = document.createElement('option');
        opt.value = u;
        opt.textContent = u;
        uniFilter.appendChild(opt);
      });

      // Generate student cards
      if (students.length === 0) {
        html += `
          <div style="text-align:center; color:#64748b; padding:40px 20px;">
            <i class="fas fa-users" style="font-size:48px; display:block; margin-bottom:16px;"></i>
            ${currentUser.role === 'student' ? 'You have no attendance records yet.' : 'No students found.'}
          </div>
        `;
      } else {
        html += `<div id="studentsList">`;
        students.forEach(student => {
          const studentRecords = records.filter(r => r.studentId === student.id);
          const presentCount = studentRecords.filter(r => r.status === 'present').length;
          const totalCount = studentRecords.length;
          const attendanceRate = totalCount > 0 ? Math.round((presentCount / totalCount) * 100) : 0;
          
          // Group records by course
          const courseGroups = {};
          studentRecords.forEach(r => {
            if (!courseGroups[r.course]) {
              courseGroups[r.course] = { present: 0, total: 0 };
            }
            courseGroups[r.course].total++;
            if (r.status === 'present') courseGroups[r.course].present++;
          });

          const courseList = Object.keys(courseGroups);
          
          html += `
            <div class="student-record-card" data-student="${student.id}">
              <div class="header">
                <div>
                  <span class="name">${student.name}</span>
                  <span class="admission">${student.admissionNo || 'No admission number'}</span>
                </div>
                <div style="text-align:right;">
                  <span style="font-size:14px; font-weight:600; color:${attendanceRate >= 70 ? '#6ee7b7' : attendanceRate >= 40 ? '#fbbf24' : '#fca5a5'};">
                    ${attendanceRate}%
                  </span>
                  <div class="attendance-progress">
                    <div class="bar ${attendanceRate >= 70 ? 'high' : attendanceRate >= 40 ? 'medium' : 'low'}" 
                         style="width:${attendanceRate}%;"></div>
                  </div>
                </div>
              </div>
              
              <div class="stats">
                <span><i class="fas fa-check-circle text-success"></i> Present: <strong class="present">${presentCount}</strong></span>
                <span><i class="fas fa-times-circle text-danger"></i> Absent: <strong class="absent">${totalCount - presentCount}</strong></span>
                <span><i class="fas fa-calendar-alt"></i> Total: <strong>${totalCount}</strong></span>
                <span><i class="fas fa-book"></i> Courses: <strong>${courseList.length}</strong></span>
              </div>
              
              <div class="courses">
                <div style="font-size:12px; color:#94a3b8; margin-bottom:4px;">
                  <i class="fas fa-graduation-cap"></i> Course Breakdown:
                </div>
                ${courseList.map(course => {
                  const data = courseGroups[course];
                  const courseRate = Math.round((data.present / data.total) * 100);
                  return `
                    <div class="course-item">
                      <span class="course-name">${course}</span>
                      <span class="attendance-count" style="color:${courseRate >= 70 ? '#6ee7b7' : courseRate >= 40 ? '#fbbf24' : '#fca5a5'};">
                        ${data.present}/${data.total} (${courseRate}%)
                      </span>
                    </div>
                  `;
                }).join('')}
              </div>
              
              <div style="margin-top:8px; font-size:11px; color:#64748b; border-top:1px solid rgba(255,255,255,0.04); padding-top:8px;">
                <i class="fas fa-clock"></i> Last attendance: ${studentRecords.length > 0 ? new Date(studentRecords[studentRecords.length - 1].timestamp).toLocaleDateString() : 'Never'}
                ${student.university ? ` • ${student.university}` : ''}
                ${student.department ? ` • ${student.department}` : ''}
              </div>
            </div>
          `;
        });
        html += `</div>`;
      }

      container.innerHTML = html;
    }

    // ============================================================
