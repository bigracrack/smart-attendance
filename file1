    window.filterStudents = function() {
      const searchTerm = document.getElementById('studentSearch').value.toLowerCase();
      const courseFilter = document.getElementById('courseFilter').value;
      const universityFilter = document.getElementById('universityFilter').value;
      
      const cards = document.querySelectorAll('.student-record-card');
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        const matchesSearch = text.includes(searchTerm);
        const matchesCourse = courseFilter === '' || text.includes(courseFilter.toLowerCase());
        const matchesUniversity = universityFilter === '' || text.includes(universityFilter.toLowerCase());
        
        card.style.display = (matchesSearch && matchesCourse && matchesUniversity) ? 'block' : 'none';
      });
    };

