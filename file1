            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Phone</span>
              <span style="font-weight:500;">${currentUser.phone || 'Not provided'}</span>
            </div>
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Department</span>
              <span style="font-weight:500;">${currentUser.department || 'Not specified'}</span>
            </div>
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Universities</span>
              <span style="font-weight:500;">${currentUser.universities ? currentUser.universities.join(', ') : 'None'}</span>
            </div>
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Qualifications</span>
              <span style="font-weight:500; text-align:right; flex:1;">${currentUser.qualifications || 'Not provided'}</span>
            </div>
            ${currentUser.documents && currentUser.documents.length > 0 ? `
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Documents</span>
              <span style="font-weight:500;">${currentUser.documents.join(', ')}</span>
            </div>
            ` : ''}
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Verification Status</span>
              <span style="font-weight:500; color:${currentUser.verificationStatus === 'verified' ? '#6ee7b7' : currentUser.verificationStatus === 'pending' ? '#fbbf24' : '#fca5a5'};">
                ${currentUser.verificationStatus === 'verified' ? '✅ Verified' : currentUser.verificationStatus === 'pending' ? '⏳ Pending' : '❌ Rejected'}
              </span>
            </div>
          ` : `
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Phone</span>
              <span style="font-weight:500;">${currentUser.phone || 'Not provided'}</span>
            </div>
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Department</span>
              <span style="font-weight:500;">${currentUser.department}</span>
            </div>
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">University</span>
              <span style="font-weight:500;">${currentUser.university}</span>
            </div>
            ${currentUser.staffId ? `
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Staff ID</span>
              <span style="font-weight:500;">${currentUser.staffId}</span>
            </div>
            ` : ''}
            ${currentUser.authLetter ? `
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Authorization Letter</span>
              <span style="font-weight:500;">${currentUser.authLetter}</span>
            </div>
            ` : ''}
            <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px;">
              <span style="color:#94a3b8;">Admin Status</span>
              <span style="font-weight:500; color:${currentUser.adminStatus === 'active' ? '#6ee7b7' : '#fbbf24'};">
                ${currentUser.adminStatus === 'active' ? '✅ Active' : '⏳ Pending'}
              </span>
            </div>
          `}
          <div class="receipt-row" style="display:flex; justify-content:space-between; padding:8px 0; font-size:14px;">
            <span style="color:#94a3b8;">Member Since</span>
            <span style="font-weight:500;">${new Date(currentUser.createdAt).toLocaleDateString()}</span>
          </div>
        </div>
      `;
    }

    // ============================================================
    // ADMIN PANEL
    // ============================================================
    function renderAdminPanel() {
      const container = document.getElementById('adminContent');
      
      if (currentUser.role !== 'admin') {
        container.innerHTML = `
          <div style="text-align:center; padding:40px 20px;">
            <i class="fas fa-lock" style="font-size:48px; color:#ef4444; display:block; margin-bottom:16px;"></i>
            <h3 style="color:#e2e8f0; margin-bottom:8px;">Access Denied</h3>
            <p style="color:#94a3b8; font-size:14px;">You do not have administrator privileges.</p>
          </div>
        `;
        return;
      }

      const users = getUsers();
      const sessions = getSessions();
      const records = getAttendanceRecords();
      const pendingLecturers = users.filter(u => u.role === 'lecturer' && u.verificationStatus === 'pending');

      let html = `
        <div style="margin-bottom:20px;">
          <h3 style="font-size:16px; color:#e2e8f0;">
            <i class="fas fa-user-shield" style="color:#fbbf24;"></i> Administrator Dashboard
          </h3>
          <p style="font-size:13px; color:#94a3b8; margin-top:4px;">Manage users, verify lecturers, and monitor system activity</p>
        </div>
        
        <div class="dashboard-grid">
          <div class="stat-card" onclick="switchDashboardTab('students')">
            <div class="number">${users.filter(u => u.role === 'student').length}</div>
            <div class="label">Students</div>
          </div>
          <div class="stat-card">
            <div class="number">${users.filter(u => u.role === 'lecturer').length}</div>
            <div class="label">Lecturers</div>
          </div>
          <div class="stat-card" onclick="switchDashboardTab('admin')">
            <div class="number">${sessions.length}</div>
            <div class="label">Total Sessions</div>
          </div>
          <div class="stat-card" onclick="switchDashboardTab('admin')">
            <div class="number">${records.length}</div>
            <div class="label">Attendance Records</div>
          </div>
          <div class="stat-card" style="border-color: ${pendingLecturers.length > 0 ? '#fbbf24' : 'transparent'};">
            <div class="number" style="color: ${pendingLecturers.length > 0 ? '#fbbf24' : '#a78bfa'};">${pendingLecturers.length}</div>
            <div class="label">Pending Verifications ${pendingLecturers.length > 0 ? '⚠️' : ''}</div>
          </div>
        </div>
      `;

      // Pending Verifications Section
      if (pendingLecturers.length > 0) {
        html += `
          <div style="margin-top:20px;">
            <h4 style="color:#fbbf24; margin-bottom:12px;">
              <i class="fas fa-clock"></i> Pending Lecturer Verifications (${pendingLecturers.length})
            </h4>
            <div class="verification-list">
              ${pendingLecturers.map(lecturer => `
                <div class="verification-item">
                  <div class="info">
                    <div class="name">${lecturer.name}</div>
                    <div class="details">
                      📧 ${lecturer.email} • 📱 ${lecturer.phone || 'No phone'} • 
                      📚 ${lecturer.universities ? lecturer.universities.join(', ') : 'No university'}
                      ${lecturer.qualifications ? `<br>🎓 ${lecturer.qualifications}` : ''}
                      ${lecturer.documents && lecturer.documents.length > 0 ? `<br>📎 Documents: ${lecturer.documents.join(', ')}` : ''}
                    </div>
                  </div>
                  <div class="actions">
                    <button onclick="verifyLecturer('${lecturer.id}')" class="btn btn-success btn-sm">
                      <i class="fas fa-check"></i> Verify
                    </button>
                    <button onclick="rejectLecturer('${lecturer.id}')" class="btn btn-danger btn-sm">
                      <i class="fas fa-times"></i> Reject
                    </button>
                    <button onclick="viewLecturerDetails('${lecturer.id}')" class="btn btn-secondary btn-sm">
                      <i class="fas fa-eye"></i> View
                    </button>
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      }

      // All Users Section
      html += `
        <div style="margin-top:20px;">
          <h4 style="color:#e2e8f0; margin-bottom:12px;">
            <i class="fas fa-users"></i> All Users (${users.length})
          </h4>
          <div class="verification-list" style="max-height:300px;">
            ${users.map(user => `
              <div class="verification-item" style="border-left: 3px solid ${user.role === 'admin' ? '#fbbf24' : user.role === 'lecturer' ? '#a78bfa' : '#10b981'};">
                <div class="info">
                  <div class="name">${user.name}</div>
                  <div class="details">
                    📧 ${user.email} • ${user.role.charAt(0).toUpperCase() + user.role.slice(1)}
                    ${user.role === 'lecturer' ? ` • ${user.verificationStatus === 'verified' ? '✅ Verified' : user.verificationStatus === 'pending' ? '⏳ Pending' : '❌ Rejected'}` : ''}
                    ${user.university ? ` • ${user.university}` : ''}
                    ${user.role === 'student' ? ` • ${user.admissionNo || 'No admission'}` : ''}
                  </div>
                </div>
                <div style="font-size:12px; color:#64748b;">
                  ${new Date(user.createdAt).toLocaleDateString()}
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      `;

      container.innerHTML = html;
    }

    // ============================================================
    // ADMIN ACTIONS
    // ============================================================
    window.verifyLecturer = function(userId) {
      if (!confirm('Verify this lecturer? They will be able to create attendance sessions.')) return;
      
      const users = getUsers();
      const user = users.find(u => u.id === userId);
      if (user) {
        user.verificationStatus = 'verified';
        saveUsers(users);
        showToast(`✅ ${user.name} has been verified as a lecturer.`, 'success');
        renderAdminPanel();
        updateDashboard();
      }
    };

    window.rejectLecturer = function(userId) {
      const reason = prompt('Enter reason for rejection (optional):');
      if (reason === null) return;
      
      const users = getUsers();
      const user = users.find(u => u.id === userId);
      if (user) {
        user.verificationStatus = 'rejected';
        user.rejectionReason = reason || 'No reason provided';
        saveUsers(users);
        showToast(`❌ ${user.name} has been rejected.`, 'error');
        renderAdminPanel();
        updateDashboard();
      }
    };

    window.viewLecturerDetails = function(userId) {
      const users = getUsers();
      const user = users.find(u => u.id === userId);
      if (!user) return;
      
      alert(`📋 Lecturer Details\n\n` +
            `Name: ${user.name}\n` +
            `Email: ${user.email}\n` +
            `Phone: ${user.phone || 'Not provided'}\n` +
            `Department: ${user.department || 'Not specified'}\n` +
            `Universities: ${user.universities ? user.universities.join(', ') : 'None'}\n` +
            `Qualifications: ${user.qualifications || 'Not provided'}\n` +
            `Documents: ${user.documents && user.documents.length > 0 ? user.documents.join(', ') : 'None'}\n` +
            `Status: ${user.verificationStatus}\n` +
            `Joined: ${new Date(user.createdAt).toLocaleDateString()}`);
    };

    // ============================================================
    // INIT
    // ============================================================
    function init() {
      // Create demo accounts
      createDemoAccounts();
      
      // Populate university dropdown
      populateUniversities();
      
      // Add event listeners for cascading dropdowns
      document.getElementById('regUniversity')?.addEventListener('change', updateCourses);
      document.getElementById('regSchool')?.addEventListener('change', updateDepartments);
      document.getElementById('regDepartment')?.addEventListener('change', updateCoursesByDept);

      // Check for verification link in URL
      const urlParams = new URLSearchParams(window.location.search);
      const verifyToken = urlParams.get('verify');
      const verifyEmail = urlParams.get('email');
      
      if (verifyToken && verifyEmail) {
        const users = getUsers();
        const user = users.find(u => u.email === verifyEmail);
        if (user && user.verificationToken === verifyToken) {
          user.verified = true;
          user.verificationToken = null;
          saveUsers(users);
          showToast('✅ Email verified successfully! You can now log in.', 'success');
          window.history.replaceState({}, '', window.location.pathname);
        } else {
          showToast('❌ Invalid or expired verification link.', 'error');
        }
      }

      // Check if user is already logged in
      const savedUser = getCurrentUser();
      if (savedUser) {
        const users = getUsers();
        const user = users.find(u => u.id === savedUser.id);
        if (user && user.verified) {
          currentUser = user;
          showDashboard();
          return;
        }
        clearCurrentUser();
      }

      showAuth();
      
      const today = new Date();
      const dateStr = today.toISOString().split('T')[0];
      const dateInput = document.getElementById('sessionDate');
      if (dateInput) dateInput.value = dateStr;
      
      const now = new Date();
      const timeInput = document.getElementById('sessionTime');
      if (timeInput) {
        timeInput.value = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
      }

      console.log('✅ Smart Attendance System - Kenya Edition loaded.');
      console.log('🎓 Student: student@demo.com / student123');
      console.log('👨‍🏫 Lecturer: lecturer@demo.com / lecturer123');
      console.log('👨‍💼 Admin: admin@demo.com / admin123');
      console.log('📊 New "Students" tab shows complete attendance history for all students');
      console.log('🔑 Click "Administrator Access" on login page for demo credentials');
    }

    // Run on load
    init();

  })();
</script>
</body>
</html>
