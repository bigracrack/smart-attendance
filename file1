    // ============================================================
    // CREATE SESSION
    // ============================================================
    window.handleCreateSession = async function(e) {
      e.preventDefault();

      const course = document.getElementById('sessionCourse').value.trim();
      const courseCode = document.getElementById('sessionCourseCode').value.trim();
      const unit = document.getElementById('sessionUnit').value.trim();
      const date = document.getElementById('sessionDate').value;
      const time = document.getElementById('sessionTime').value;
      const university = document.getElementById('sessionUniversity').value;

      if (!course || !courseCode || !unit || !date || !time) {
        showToast('⚠️ Please fill in all fields.', 'error');
        return;
      }

      const location = await getHostLocation();
      if (!location) {
        showToast('⚠️ Unable to get your location. Please enable GPS.', 'error');
        return;
      }

      const sessionCode = generateSessionCode();
      const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
      const dateObj = new Date(date + 'T' + time);
      const dayOfWeek = days[dateObj.getDay()];
      const dateParts = date.split('-');
      const formattedDate = `${dateParts[2]}. ${dateParts[1]}. ${dateParts[0]}`;
      const timeParts = time.split(':');
      const hour = parseInt(timeParts[0]);
      const hour12 = hour % 12 || 12;
      const ampm = hour >= 12 ? 'PM' : 'AM';
      const formattedTime = `${hour12}:${timeParts[1]} ${ampm}`;

      const session = {
        id: Date.now().toString(),
        hostId: currentUser.id,
        hostName: currentUser.name,
        course,
        courseCode,
        unit,
        date: formattedDate,
        time: formattedTime,
        dayOfWeek,
        sessionCode,
        hostLocation: location,
        startTime: new Date().toISOString(),
        active: true,
        university: university || (currentUser.universities ? currentUser.universities[0] : 'Various'),
        department: currentUser.department || 'General'
      };

      const sessions = getSessions();
      sessions.push(session);
      saveSessions(sessions);

      sessionData = session;
      sessionActive = true;
      attendees = [];

      showToast(`✅ Session started! Code: ${sessionCode}`, 'success');
      renderAttendancePanel();
      updateDashboard();
      hideCreateSession();
    };

    // ============================================================
    // END SESSION
    // ============================================================
    window.endSession = function(sessionId) {
      if (!confirm('End this session? Students will no longer be able to sign in.')) return;

      const sessions = getSessions();
      const session = sessions.find(s => s.id === sessionId);
      if (session) {
        session.active = false;
        session.endTime = new Date().toISOString();
        saveSessions(sessions);
      }

      sessionActive = false;
      sessionData = null;
      attendees = [];
      showToast('⏹️ Session ended.', '');
      renderAttendancePanel();
      updateDashboard();
    };

    // ============================================================
    // EXPORT ATTENDANCE
    // ============================================================
    window.exportAttendance = function(sessionId) {
      const records = getAttendanceRecords().filter(r => r.sessionId === sessionId);
      if (records.length === 0) {
        showToast('⚠️ No attendance records to export.', 'error');
        return;
      }

      let csv = 'Name,Admission Number,Student ID,University,School,Department,Year,Course,Time,Distance (m),Status\n';
      records.forEach(r => {
        csv += `${r.studentName},${r.admissionNo || ''},${r.studentId || ''},${r.university || ''},${r.school || ''},${r.department || ''},${r.yearOfStudy || ''},${r.course || ''},${r.time},${r.distance},${r.status}\n`;
      });

      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `attendance_${sessionId}.csv`;
      a.click();
      URL.revokeObjectURL(url);
      showToast('✅ Attendance exported successfully!', 'success');
    };

