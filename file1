    // ============================================================
    // STUDENT SIGN IN
    // ============================================================
    window.handleStudentSignIn = async function(e, sessionId) {
      e.preventDefault();

      const code = document.getElementById('studentSignInCode').value.trim().toUpperCase();
      const sessions = getSessions();
      const session = sessions.find(s => s.id === sessionId);

      if (!session || !session.active) {
        showToast('⚠️ This session is no longer active.', 'error');
        return;
      }

      if (code !== session.sessionCode) {
        showToast('❌ Invalid session code. Please check with your host.', 'error');
        return;
      }

      const records = getAttendanceRecords();
      if (records.find(r => r.sessionId === sessionId && r.studentId === currentUser.id)) {
        showToast('⚠️ You have already signed in for this session.', 'error');
        return;
      }

      const location = await getStudentLocation();
      if (!location) {
        showToast('⚠️ Unable to get your location. Please enable GPS.', 'error');
        return;
      }

      const distance = calculateDistance(
        session.hostLocation.lat,
        session.hostLocation.lng,
        location.lat,
        location.lng
      );

      const result = document.getElementById('studentSignInResult');
      
      if (distance > 10) {
        result.style.display = 'block';
        result.innerHTML = `
          <div style="text-align:center; padding:16px; color:#fca5a5;">
            <i class="fas fa-times-circle" style="font-size:32px; display:block; margin-bottom:8px; color:#ef4444;"></i>
            <strong>❌ Out of Range</strong>
            <p style="font-size:13px; margin-top:6px;">You are ${Math.round(distance)}m away. Must be within 10m of the host.</p>
            <p style="font-size:12px; color:#64748b;">Please move closer to the host location.</p>
          </div>
        `;
        showToast(`❌ Too far (${Math.round(distance)}m). Need to be within 10m.`, 'error');
        return;
      }

      const now = new Date();
      const timeStr = now.toLocaleTimeString('en-US', { hour12: true, hour: '2-digit', minute: '2-digit', second: '2-digit' });

      const attendanceRecord = {
        id: Date.now().toString(),
        sessionId: session.id,
        studentId: currentUser.id,
        studentName: currentUser.name,
        studentEmail: currentUser.email,
        admissionNo: currentUser.admissionNo,
        studentIdNumber: currentUser.studentId || '',
        university: currentUser.university,
        school: currentUser.school,
        department: currentUser.department,
        yearOfStudy: currentUser.yearOfStudy,
        course: currentUser.course,
        time: timeStr,
        timestamp: now.toISOString(),
        distance: Math.round(distance),
        status: 'present',
        hostId: session.hostId
      };

      records.push(attendanceRecord);
      saveAttendanceRecords(records);

      session.attendanceCount = (session.attendanceCount || 0) + 1;
      saveSessions(sessions);

      result.style.display = 'block';
      result.innerHTML = `
        <div style="padding:16px; color:#6ee7b7;">
          <i class="fas fa-check-circle" style="font-size:32px; display:block; margin-bottom:8px; color:#34d399;"></i>
          <strong>✅ Signed In Successfully!</strong>
          <p style="font-size:13px; margin-top:6px; color:#94a3b8;">Within ${Math.round(distance)}m of host</p>
          <div style="font-size:12px; color:#64748b; margin-top:8px;">
            ${session.course} • ${session.date} at ${session.time}
          </div>
        </div>
      `;

      showToast(`✅ ${currentUser.name} signed in successfully!`, 'success');
      document.getElementById('studentSignInCode').value = '';
      renderAttendancePanel();
      updateDashboard();
    };

