        document.getElementById('sessionDate').value = today.toISOString().split('T')[0];
        const now = new Date();
        document.getElementById('sessionTime').value = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
